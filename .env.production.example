# =========================================================================
# TubePath — PRODUCTION env vars for Vercel (tubepath.org)
#
# Copy each line into Vercel → Project → Settings → Environment Variables
# (Production). Paste your SECRET values from .env.local — this file has
# only the URLs pre-filled for tubepath.org.
#
# GOOGLE_REDIRECT_URI is optional — the app builds it from NEXT_PUBLIC_APP_URL.
# =========================================================================

NEXT_PUBLIC_APP_URL=https://tubepath.org

GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

SESSION_SECRET=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
