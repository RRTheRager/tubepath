# =========================================================================
# TubePath environment variables
# Everything is OPTIONAL. With no keys set, the app runs fully in demo mode:
#   - rich mock analytics data
#   - simulated billing (toggle trial / active / lapsed states in Settings)
#   - canned AI fallbacks
#   - in-memory accounts (reset on server restart)
# Add keys progressively to enable real data, real AI, real billing, and
# durable storage.
# =========================================================================

# App URL — production default is https://tubepath.org (see DEPLOY-TUBEPATH.md)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- AI (Google Gemini) -------------------------------------------------
# Get a key: https://aistudio.google.com/app/apikey
# When unset, AI features return graceful canned suggestions.
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash; 2.0 was retired 2026-06-01).
# GEMINI_MODEL=gemini-3.5-flash
# On a 429/503 the app auto-retries with this model (separate quota bucket).
# GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# ---- YouTube Data + Analytics (Google OAuth) ----------------------------
# https://console.cloud.google.com/  (enable YouTube Data API v3 + Analytics)
# When unset, the app uses the mock data provider.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override — defaults to {NEXT_PUBLIC_APP_URL}/api/auth/callback/google
# GOOGLE_REDIRECT_URI=

# ---- Stripe billing -----------------------------------------------------
# https://dashboard.stripe.com/apikeys
# When unset, billing runs in SIMULATED mode (no real charges).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Secret used to sign the lightweight session cookie (any random string)
SESSION_SECRET=

# ---- Database (Supabase / Postgres) -------------------------------------
# https://supabase.com/  -> Project Settings -> API
# When unset, accounts + YouTube tokens are kept IN MEMORY (reset on restart).
# Set both to persist users, subscriptions, and connected channels.
# Run supabase/schema.sql once in the Supabase SQL editor to create tables.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
